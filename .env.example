# ===========================================
# Linear Health - Environment Configuration Template
# ===========================================

# --- Application ---
APP_NAME='Linear Health HMS'
APP_ENV=development
DEBUG=True
SECRET_KEY=default-insecure-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- PostgreSQL ---
POSTGRES_USER=linearhealth
POSTGRES_PASSWORD=postgres_default_password
POSTGRES_DB=hospital_management
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://linearhealth:postgres_default_password@postgres:5432/hospital_management

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Groq API ---
GROQ_API_KEY=your_groq_api_key_here

# --- LiveKit ---
LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Admin Credentials ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# --- Agent Credentials ---
AGENT_EMAIL=ai-agent@linearhealth.com
AGENT_PASSWORD=change_me_in_production

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
